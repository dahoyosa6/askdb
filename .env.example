# ─────────────────────────────────────────────────────────────
# AskDB — "Habla con tus Datos"  ·  Plantilla de variables de entorno
# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.
# ─────────────────────────────────────────────────────────────

# --- Anthropic (genera el SQL y redacta la respuesta) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=2048

# --- Base de datos (Neon Postgres) ---
# Northwind vive en Neon (free tier). DATABASE_URL usa el rol de SOLO LECTURA
# (askdb_readonly), NO el rol owner. Formato Neon:
#   postgresql://askdb_readonly:[PASSWORD]@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://askdb_readonly:xxxx@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# NEON_ADMIN_URL: conexión owner de Neon, SOLO para setup inicial (cargar datos +
# crear el rol read-only). Se borra de aquí una vez hecho el setup. No va a runtime.
# NEON_ADMIN_URL=postgresql://neondb_owner:xxxx@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DB_STATEMENT_TIMEOUT_MS=8000
DB_POOL_MIN=1
DB_POOL_MAX=5

# --- Límites y comportamiento del agente ---
QUERY_ROW_HARD_CAP=1000
MAX_SQL_RETRIES=3
MEMORY_WINDOW=6
RATE_LIMIT_PER_MIN=10
# Duración máxima de una nota de voz en segundos; una más larga se rechaza.
MAX_VOICE_DURATION_S=120

# --- Telegram (Fase 6) ---
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxxxxxxxxxxxxxxxxx
# IDs de chat autorizados, separados por coma. Ej: 12345678,87654321
ALLOWED_CHAT_IDS=
TELEGRAM_USE_WEBHOOK=false
WEBHOOK_URL=
# Cadena aleatoria para validar que el webhook viene de Telegram (no de un
# atacante). Telegram la reenvía en la cabecera X-Telegram-Bot-Api-Secret-Token
# en cada update; la app rechaza (403) cualquier petición sin ella o con un valor
# distinto. Usa A–Z/a–z/0–9 y los símbolos - y _ (entre 1 y 256 caracteres).
WEBHOOK_SECRET=

# --- Groq (transcripción de voz, Fase 7) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_WHISPER_MODEL=whisper-large-v3

# --- Salidas y logging ---
OUTPUT_DIR=outputs
CHART_MAX_ROWS=50
TABLE_MAX_ROWS_TEXT=20
SCHEMA_CACHE_PATH=db/schema_cache.json
LOG_LEVEL=INFO
